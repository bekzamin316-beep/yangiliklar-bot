# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=-1001234567890
ADMIN_ID=123456789

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/crypto_news_bot
REDIS_URL=redis://redis:6379/0

# AI Provider Configuration
AI_PROVIDER=openrouter
AI_MODEL=meta-llama/llama-3-70b-instruct
OPENROUTER_API_KEY=your_openrouter_key
GROQ_API_KEY=your_groq_key
GOOGLE_API_KEY=your_google_key
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
OLLAMA_BASE_URL=http://ollama:11434

# RSS Sources (comma-separated URLs)
RSS_SOURCES=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss,https://announcements.binance.com/en/feed,https://blog.bybit.com/feed/,https://medium.com/feed/okx,https://medium.com/feed/kucoin

# CryptoPanic API (optional)
CRYPTOPANIC_API_KEY=your_cryptopanic_key

# CoinGecko API (optional)
COINGECKO_API_KEY=your_coingecko_key

# Scheduler Configuration
DIGEST_TIME=23:59
DIGEST_TIMEZONE=UTC
NEWS_CHECK_INTERVAL=300

# System Configuration
LOG_LEVEL=INFO
MAX_RETRIES=3
REQUEST_TIMEOUT=30
IMPORTANCE_THRESHOLD=50

# Security
ENCRYPTION_KEY=your_encryption_key_here
